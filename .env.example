# Provider API keys are saved in the in-app settings form and stay in the browser.
# This file is only for optional server-side defaults such as storage.

# Optional. Defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional. Enables S3-compatible uploads. The same values can also be saved in
# the in-app provider settings form.
STORAGE_PROVIDER=
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_BUCKET=
STORAGE_S3_PUBLIC_DOMAIN=
STORAGE_S3_PATH_PREFIX=uploads
